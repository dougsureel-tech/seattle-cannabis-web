#!/bin/bash
# glw pre-push gates — wires all 9 arc-guards from `scripts/check-*.mjs`
# to fire on every `git push`. Pre-T118 the gates existed as scripts but
# were only run manually — pushes could land violations of og-completeness
# / title-length / button-type / csp-report-only / etc rules without
# blocking.
#
# Bypass: `git push --no-verify` (use only when you've explicitly verified
# the gate is misfiring; see GW pre-push T117 for false-positive precedent
# where check-og-completeness needed an EXEMPT-set update).
#
# Sister of GW v2.97.S0 17/17 pre-push chain. Activate via:
#   bash scripts/setup-hooks.sh
# (which runs `git config core.hooksPath .githooks`)

# ── 0. Changelog guard (TS code change must bump lib/version.ts) ─────────
# Doug's standing rule: every push that lands code bumps BUILD_VERSION +
# adds a changelog comment line. Pre-fix the rule was honored manually
# but unenforced — a future agent's TS-only push could land without a
# version bump and Doug couldn't tell "is this deploy live yet?" from
# the footer pill.
#
# Bypass: `git push --no-verify` for true doc-only / refactor-only pushes
# (or include `[doc-skip]` in the commit subject — sister of inv pattern).
while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    CHANGED=$(git diff-tree --no-commit-id -r --name-only "$local_sha" 2>/dev/null)
  else
    CHANGED=$(git diff --name-only "$remote_sha" "$local_sha" 2>/dev/null)
  fi

  TS_CHANGED=$(echo "$CHANGED" | grep -E '\.(ts|tsx)$' | grep -v 'lib/version\.ts')
  VERSION_CHANGED=$(echo "$CHANGED" | grep 'lib/version\.ts')

  DOC_SKIP=$(git log --format=%s "${remote_sha}..${local_sha}" 2>/dev/null | grep -c '\[doc-skip\]')

  if [ -n "$TS_CHANGED" ] && [ -z "$VERSION_CHANGED" ] && [ "$DOC_SKIP" -eq 0 ]; then
    echo ""
    echo "  ✗ Push blocked: .ts/.tsx changed but lib/version.ts (BUILD_VERSION + changelog) was not updated."
    echo "    Add a new entry at the top of lib/version.ts + bump BUILD_VERSION, or:"
    echo "    - add [doc-skip] to a commit subject if this is genuinely refactor-only"
    echo "    - bypass: git push --no-verify"
    echo ""
    exit 1
  fi
done

# ── 1. TypeScript check (catch type errors before Vercel deploy) ─────────
echo "  Running TypeScript check..."
if ! ./node_modules/.bin/tsc --noEmit 2>&1; then
  echo ""
  echo "  ✗ Push blocked: TypeScript errors found above. Fix them before pushing."
  echo "    Or bypass: git push --no-verify"
  echo ""
  exit 1
fi
echo "  ✓ TypeScript OK"

# ── 2. Build-gates umbrella (9 arc-guards) ────────────────────────────────
echo "  Running build-gates..."
for gate in \
  scripts/check-site-url-defense.mjs \
  scripts/check-og-completeness.mjs \
  scripts/check-duplicate-brand-title.mjs \
  scripts/check-og-image-shape.mjs \
  scripts/check-per-route-og-image.mjs \
  scripts/check-title-length-html.mjs \
  scripts/check-description-length-html.mjs \
  scripts/check-button-type.mjs \
  scripts/check-csp-report-only.mjs \
  scripts/check-html-entities-jsx.mjs \
  scripts/check-server-actions-async.mjs \
  scripts/check-pii-console-leak.mjs \
  scripts/check-breadcrumb-ld-id.mjs \
  scripts/check-redirect-shadow.mjs \
  scripts/check-no-store-isr-poison.mjs \
  scripts/check-customer-cta-order-href.mjs \
  scripts/check-fabricated-review-schema.mjs \
  scripts/check-usesyncexternalstore-cache.mjs \
  scripts/check-conflict-markers.mjs \
  scripts/check-time-constants-inline.mjs \
  scripts/check-fs-read-bundled.mjs \
  scripts/check-inline-form-action-tuple-discard.mjs \
  scripts/check-cross-store-url-leak.mjs \
  scripts/check-brand-voice-locally-owned.mjs \
  scripts/check-efficacy-claims.mjs \
  scripts/check-loyalty-math-drift.mjs \
  scripts/check-please-hedge.mjs \
  scripts/check-template-warmth.mjs \
  scripts/check-apologize-pattern.mjs \
  scripts/check-store-name-double-period.mjs \
  scripts/check-no-unsafe-redirect.mjs \
  scripts/check-metadata-exclusive.mjs \
  scripts/check-env-example-unique.mjs \
  scripts/check-imageresponse-cache-pattern.mjs \
  scripts/check-aria-current.mjs \
  scripts/check-client-imports-no-server-only.mjs \
  scripts/check-use-server-exports.mjs \
  scripts/check-resend-via-helper.mjs \
  scripts/check-buildcommand-length.mjs; do
  if ! node "$gate" 2>&1; then
    echo ""
    echo "  ✗ Push blocked: $gate failed above. Fix before pushing."
    echo "    Or bypass: git push --no-verify"
    echo ""
    exit 1
  fi
done
echo "  ✓ Build-gates OK (31/31)"

# ── 3. Lib unit tests (node:test pin tests on lib/__tests__/*.ts) ─────────
echo "  Running lib tests..."
if ! node --test --experimental-strip-types --no-warnings lib/__tests__/*.test.ts 2>&1; then
  echo ""
  echo "  ✗ Push blocked: lib tests failed above. Fix before pushing."
  echo "    Or bypass: git push --no-verify"
  echo ""
  exit 1
fi
echo "  ✓ Lib tests OK"

exit 0
