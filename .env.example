# Seattle Cannabis Co (seattle-cannabis-web) — env-var spec.
#
# Public marketing + customer-PWA site. Sister of greenlife-web with
# nearly-identical env shape. inventoryapp (admin/POS) lives in the sibling
# `Inventory App/` repo; cross-stack push integration via NEXT_PUBLIC_INVENTORYAPP_URL.
#
# Sea-only delta vs glw: scc has DASHBOARD_SESSION_SECRET (rewards-OTP HMAC)
# + NODE_ENV / VERCEL_ENV reads (defense-in-depth NODE_ENV gates added v11.505).
#
# Pattern:
#   - `NEXT_PUBLIC_*` exposed to client bundle (per-store branding, build SHA,
#     CAPTCHA site key, push public VAPID key, GA tag, feature flags)
#   - everything else is server-only (DB URL, secrets, private keys)

# ── Database (required) ────────────────────────────────────────────────
# Postgres connection string. Production uses Vercel Neon integration which
# auto-injects POSTGRES_URL_NON_POOLING + POSTGRES_URL.
# Per memory project_seattle_neon_shared_with_wen — Sea is on its OWN Neon
# project (`seattle-cannabis-db`), NOT shared with Wen.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/seattle_cannabis
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# ── Site identity ──────────────────────────────────────────────────────
# Canonical origin (no trailing slash). Used for canonical link tags + OG +
# absolute URL building in emails. iHJ Boost embed origin-binds against
# the `www.` host (per memory reference_iheartjane_cors_origin) — apex
# silent-rejects, must keep `www.` prefix.
NEXT_PUBLIC_SITE_URL=https://www.seattlecannabis.co
NEXT_PUBLIC_SITE_ORIGIN=https://www.seattlecannabis.co

# Build version label rendered in the footer for "did my push land" check.
NEXT_PUBLIC_BUILD_VERSION=

# Vercel auto-injects VERCEL_GIT_COMMIT_SHA + the NEXT_PUBLIC_ mirror.
VERCEL_GIT_COMMIT_SHA=
NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA=
# Vercel auto-injects VERCEL_ENV ("production" | "preview" | "development").
# Used by lib/auth.ts to gate dev-only conveniences.
VERCEL_ENV=

# ── Inventoryapp (cross-stack staff-app link) ─────────────────────────
NEXT_PUBLIC_INVENTORYAPP_URL=https://brapp.seattlecannabis.co

# ── Cross-stack push (inv → scc subscribers) ──────────────────────────
# inv POSTs to scc's /api/push/send. MUST match PUSH_SEND_TOKEN on both sides.
PUSH_SEND_TOKEN=

# ── Web Push (VAPID keys for browser-push subscribers) ────────────────
# Generate via `npx web-push generate-vapid-keys`.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:doug@seattlecannabis.co

# ── Resend (transactional email) ──────────────────────────────────────
# Per memory project_seattle_rainier_email_monitored — Sea's RESEND_FROM is
# `rainier@seattlecannabis.co` (an actively-monitored mailbox, OK for
# customer reply-to per project_info_email_unmonitored sister-rule).
RESEND_API_KEY=
RESEND_FROM=rainier@seattlecannabis.co
RESEND_REPLY_TO=

# ── Twilio (transactional SMS + rewards OTP) ──────────────────────────
# REQUIRED for the SCC rewards-portal OTP flow at /rewards/login. If unset,
# the login form falls through to a demoCode dev path (gated by NODE_ENV
# at the server side per scc v11.505 — never logs demoCode in prod).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Rewards OTP session HMAC ──────────────────────────────────────────
# HMAC secret for signed rewards-session cookies. Generate with
# `openssl rand -hex 32`. Sea's rewards portal uses this to sign per-customer
# session payloads (lib/rewards-session.ts). NEVER reuse across envs.
DASHBOARD_SESSION_SECRET=

# ── Email/SMS feature gates (default OFF) ─────────────────────────────
ORDER_CONFIRMATION_EMAIL_ENABLED=
WELCOME_EMAIL_ENABLED=

# ── Quiz nurture (D+0/D+3/D+7 follow-up email sequence) ───────────────
QUIZ_NURTURE_ENABLED=
NEXT_PUBLIC_QUIZ_NURTURE_ENABLED=

# ── Cloudflare Turnstile (CAPTCHA on public forms) ────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Google Analytics 4 ────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=

# ── Search-engine site verification ───────────────────────────────────
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
YANDEX_VERIFICATION=
