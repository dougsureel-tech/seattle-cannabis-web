    "check:title-length-html": "node scripts/check-title-length-html.mjs",
    "check:description-length-html": "node scripts/check-description-length-html.mjs",
    "check:button-type": "node scripts/check-button-type.mjs",
    "check:html-entities-jsx": "node scripts/check-html-entities-jsx.mjs",
    "check:server-actions-async": "node scripts/check-server-actions-async.mjs",
    "check:pii-console-leak": "node scripts/check-pii-console-leak.mjs",
    "check:breadcrumb-ld-id": "node scripts/check-breadcrumb-ld-id.mjs",
    "check:redirect-shadow": "node scripts/check-redirect-shadow.mjs",
